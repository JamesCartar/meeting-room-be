{
	"name": "mail-backend",
	"private": true,
	"main": "src/server.js",
	"scripts": {
		"dev": "nodemon --exec ts-node -r tsconfig-paths/register --files server.ts",
		"build": "rimraf dist && tsc && tsc-alias",
		"start": "node dist/server.js",
		"seed": "ts-node -r tsconfig-paths/register src/db/seeds/index.ts",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"type-check": "tsc --noEmit",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"cors": "^2.8.5",
		"cpx": "^1.5.0",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"http-proxy-middleware": "^4.0.0",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.1.5",
		"rimraf": "^6.1.3",
		"uuid": "^13.0.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.10",
		"@types/node": "^25.0.2",
		"@types/uuid": "^10.0.0",
		"dotenv": "^17.2.3",
		"dotenv-expand": "^12.0.3",
		"lint-staged": "^16.2.7",
		"morgan": "^1.10.1",
		"nodemon": "^3.1.11",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{js,ts,json}": [
			"biome check --write --no-errors-on-unmatched --diagnostic-level=error"
		]
	}
}
